# Vacío en desarrollo: Vite enruta /api al backend (vite.config.js → localhost:3006)
VITE_API_URL=

# Mismo valor que MICROSOFT_REDIRECT_URI del backend y que la URI en Azure (puede ser :3006 aunque el SPA sea :5173).
VITE_MICROSOFT_REDIRECT_URI=http://localhost:3006/callback-microsoft

# Vistas del menú lateral (true / false). Si todas están en false, se muestra solo Asistencia.
VITE_VIEW_ASISTENCIA=true
VITE_VIEW_HISTORIAL=true
VITE_VIEW_INFORMACION=true
VITE_VIEW_RUBRICAS=true
VITE_VIEW_REPORTES=true
VITE_VIEW_ADMINISTRADOR=true

# WhatsApp de soporte para usuarios sin asignación
VITE_SUPPORT_WHATSAPP=3024562648
